ENVIRONMENT=development

# Database — DATABASE_URL takes priority for production (async-compatible):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# For local development, use TURSO_DATABASE_URL with file: prefix:
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Auth — WARNING: Without CLERK_JWKS_URL, all X-User-ID headers are trusted (dev only).
# Set this before deploying to production.
# IMPORTANT: The JWKS URL environment (test/live) must match the frontend's
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY. Mismatched environments cause silent auth failures.
CLERK_JWKS_URL=
# Optional JWT audience claim validation (leave empty to skip in dev)
CLERK_AUDIENCE=

# Payments — required for billing features
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Metrics — API key for Prometheus /metrics endpoint (min 16 chars)
METRICS_API_KEY=

# Email (Resend) — optional; emails silently skip when unconfigured
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@dualstack.app
EMAIL_FROM_NAME=DualStack

# Object storage (S3/R2) — optional; file upload features require these
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1

# Proxy hardening — trusted reverse proxy IP for X-Forwarded-For
FORWARDED_ALLOW_IPS=127.0.0.1
