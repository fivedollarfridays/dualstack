# Client-side variables (safe to expose in browser)
# IMPORTANT: Clerk key environment (test/live) must match the backend's CLERK_JWKS_URL.
# Using pk_test_ here with a live JWKS URL (or vice versa) will cause silent auth failures.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_your_pro_plan_id

# Server-side variables (Next.js server only, never sent to browser)
TURSO_DATABASE_URL=file:local.db
# For remote databases, use a READ-ONLY scoped Turso token.
# The frontend DB layer is for SSR reads only — writes go through the backend API.
# Empty token is allowed for local file: URLs in development.
TURSO_AUTH_TOKEN=
ENVIRONMENT=development

# E2E Testing (Playwright + Clerk)
# Create a test user in Clerk dashboard with username/password auth
E2E_CLERK_USER_USERNAME=
E2E_CLERK_USER_PASSWORD=
